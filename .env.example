# ─────────────────────────────────────────────
#  NewsAlphaAI  — Environment Configuration
# ─────────────────────────────────────────────

# ── LLM ──────────────────────────────────────
LLM_PROVIDER=gemma                            # gemma | openai | mistral | llama
GEMMA_MODEL_PATH=./models/LLM/Gemma-3-4B-IT
OPENAI_API_KEY=******
OPENAI_MODEL=gpt-4o-mini

# ── News APIs ─────────────────────────────────
NEWSAPI_KEY=******             # https://newsapi.org
GNEWS_API_KEY=******            # https://gnews.io  (free tier)
ALPHAVANTAGE_KEY=your_av_key_here            # news + sentiment

# ── Stock Data ────────────────────────────────
YAHOO_FINANCE_ENABLED=true                   # yfinance (always free)
ALPHAVANTAGE_STOCK_KEY=your_av_key_here

# ── Vector Database ───────────────────────────
VECTORDB_PROVIDER=chroma                     # chroma | faiss
CHROMA_PERSIST_DIR=./data/embeddings/chroma
FAISS_INDEX_DIR=./data/embeddings/faiss

# ── Data Storage ──────────────────────────────
NEWS_DATA_DIR=./data/news
STOCK_DATA_DIR=./data/stocks
MEMORY_DIR=./data/memory                     # agent long-term memory (separate)

# ── LangSmith ─────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=******
LANGCHAIN_PROJECT=NewsAlphaAI
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── ML / RL ──────────────────────────────────
ML_MODEL_DIR=./data/ml_models
RL_FEEDBACK_LOG=./data/rl/feedback.jsonl
RL_REWARD_THRESHOLD=0.6

# ── Backend Server ────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Embedding Model ───────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2            # sentence-transformers model name
